# ==========================================
# InsForge (Base de Datos y Autenticación)
# ==========================================
# (Estas variables van con VITE_ porque Astro necesita leerlas en el cliente)
VITE_INSFORGE_URL=https://tu-proyecto.region.insforge.app
VITE_INSFORGE_ANON_KEY=tu-anon-key

# ==========================================
# Telegram Bot (Para las Cotizaciones)
# ==========================================
# (Estas variables NO llevan VITE_ porque solo deben usarse en el servidor)
TELEGRAM_BOT_TOKEN=tu-token-de-botfather
TELEGRAM_OWNER_CHAT_ID=tu-chat-id-personal
TELEGRAM_WEBHOOK_SECRET=tu-secreto-inventado
