---
interface Feature {
  title: string;
  description: string;
}

interface Props {
  title?: string;
  features: Feature[];
}

const { title, features } = Astro.props;
---

<section class="bg-background">
  <div class="section-container">
    {title && <h2 class="mb-8 text-2xl md:text-3xl font-bold text-text-heading">{title}</h2>}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feature) => (
        <article class="card p-6">
          <h3 class="text-lg font-bold text-text-heading mb-3">{feature.title}</h3>
          <p class="text-sm leading-relaxed text-text-body">{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
