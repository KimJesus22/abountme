---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
}

const { badge, title, subtitle } = Astro.props;
---

<section class="bg-background pt-32 md:pt-40">
  <div class="section-container py-14 md:py-20">
    <div class="max-w-3xl">
      {badge && <p class="section-badge mb-5">{badge}</p>}
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold leading-tight text-text-heading">
        {title}
      </h1>
      {subtitle && (
        <p class="mt-6 text-lg md:text-xl leading-relaxed text-text-body">
          {subtitle}
        </p>
      )}
    </div>
  </div>
</section>
