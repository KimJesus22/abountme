---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { whatsappLink } from '../../lib/whatsapp';

interface Props {
  icon: string;
  title: string;
  description: string;
  value: string;
  lang?: Lang;
}

const { icon, title, description, value, lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const waMessageMap: Record<string, string> = {
  'buy-phone': 'Hola José, quiero asesoría para comprar un celular. Mi presupuesto aproximado es:',
  'setup-phone': 'Hola José, quiero ayuda para configurar mi celular.',
  'tech-support': 'Hola José, necesito soporte técnico.',
  'pc-build': 'Hola José, quiero ayuda para revisar, mejorar o armar una PC/laptop.',
  'laptop-advice': 'Hola José, quiero ayuda para revisar, mejorar o armar una PC/laptop.',
  'simple-web': 'Hola José, quiero cotizar una página web sencilla.',
  'business-digital': 'Hola José, quiero cotizar una solución digital para mi negocio.',
  'basic-security': 'Hola José, quiero ayuda con seguridad digital.',
};
const waMsg = waMessageMap[value] || 'Hola José, vi tu página y me gustaría más información sobre tus servicios.';
const waHref = whatsappLink(waMsg);
---

<div class="card card-hover p-6 md:p-8 group flex flex-col h-full">
  <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-2xl mb-5 group-hover:scale-110 group-hover:bg-primary-100 transition-all duration-300">
    {icon}
  </div>
  <h3 class="font-display font-semibold text-lg text-text-heading mb-2">
    {title}
  </h3>
  <p class="text-text-body text-sm leading-relaxed flex-1 mb-6">
    {description}
  </p>
  
  <div class="flex items-center gap-4 mt-auto">
    <a href="#quote" onclick={`document.getElementById('service_type').value='${value}'`} class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-dark transition-colors">
      {t('services.cta')}
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
    <a href={waHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm font-semibold text-[#25D366] hover:text-[#1fb855] transition-colors" title="Contactar por WhatsApp">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      WhatsApp
    </a>
  </div>
</div>
