---
const services = [
  {
    href: '/servicios/celulares',
    title: 'Celulares',
    description: 'Compra, configuración y revisión de celulares nuevos o usados.',
  },
  {
    href: '/servicios/pc-laptop',
    title: 'PC / Laptop',
    description: 'Armado, mejoras, RAM, SSD y compatibilidad de componentes.',
  },
  {
    href: '/servicios/paginas-web',
    title: 'Páginas web',
    description: 'Sitios sencillos, menús digitales, portafolios y proyectos personalizados.',
  },
  {
    href: '/servicios/negocios',
    title: 'Negocios pequeños',
    description: 'WhatsApp Business, QR, Google Maps, catálogo y menú digital.',
  },
];
---

<section class="bg-surface">
  <div class="section-container">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {services.map((service) => (
        <a href={service.href} class="card card-hover p-6 block">
          <h2 class="text-xl font-bold text-text-heading mb-3">{service.title}</h2>
          <p class="text-sm leading-relaxed text-text-body mb-5">{service.description}</p>
          <span class="text-sm font-semibold text-primary">Ver servicio</span>
        </a>
      ))}
    </div>
  </div>
</section>
