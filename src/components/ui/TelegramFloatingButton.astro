---
const botUrl = 'https://t.me/KimJesusCeronTechBot';
---

<a
  href={botUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-24 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-[#229ED9] text-white shadow-lg transition-all duration-300 hover:scale-110 hover:bg-[#1b8fc8] hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-[#229ED9]/40 focus:ring-offset-2 focus:ring-offset-background group"
  aria-label="Abrir bot de Telegram"
>
  <svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M21.944 4.667 18.62 20.342c-.251 1.106-.905 1.38-1.834.86l-5.076-3.743-2.449 2.356c-.27.27-.497.497-1.019.497l.364-5.168 9.407-8.5c.409-.364-.089-.566-.633-.202L5.754 13.76.748 12.194c-1.088-.34-1.106-1.088.227-1.61L20.552 3.04c.906-.34 1.699.202 1.392 1.627Z" />
  </svg>
  <span class="absolute right-full mr-3 whitespace-nowrap rounded-lg border border-border bg-surface px-3 py-1.5 text-sm font-medium text-text-heading opacity-0 shadow-lg transition-opacity pointer-events-none group-hover:opacity-100">
    KimJesusCeronTech
  </span>
</a>
