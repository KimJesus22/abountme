---
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import SectionHeading from "../ui/SectionHeading.astro";
import { whatsappLink, waMessages } from "../../lib/whatsapp";
import { telegramLink } from "../../lib/telegram";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const pricingData = [
  {
    icon: "📱",
    value: "buy-phone",
    titleKey: "pricing.1.title",
    rangeKey: "pricing.1.range",
    descKey: "pricing.1.desc",
    waMsgKey: "phoneAdvice"
  },
  {
    icon: "⚙️",
    value: "setup-phone",
    titleKey: "pricing.2.title",
    rangeKey: "pricing.2.range",
    descKey: "pricing.2.desc",
    waMsgKey: "phoneSetup"
  },
  {
    icon: "🔧",
    value: "tech-support",
    titleKey: "pricing.3.title",
    rangeKey: "pricing.3.range",
    descKey: "pricing.3.desc",
    waMsgKey: "techSupport"
  },
  {
    icon: "💻",
    value: "laptop-advice",
    titleKey: "pricing.4.title",
    rangeKey: "pricing.4.range",
    descKey: "pricing.4.desc",
    waMsgKey: "laptopAdvice"
  },
  {
    icon: "🖥️",
    value: "pc-build",
    titleKey: "pricing.5.title",
    rangeKey: "pricing.5.range",
    descKey: "pricing.5.desc",
    waMsgKey: "hardware"
  },
  {
    icon: "🌐",
    value: "simple-web",
    titleKey: "pricing.6.title",
    rangeKey: "pricing.6.range",
    descKey: "pricing.6.desc",
    waMsgKey: "web"
  },
  {
    icon: "🏪",
    value: "business-digital",
    titleKey: "pricing.7.title",
    rangeKey: "pricing.7.range",
    descKey: "pricing.7.desc",
    waMsgKey: "business"
  },
  {
    icon: "🛡️",
    value: "basic-security",
    titleKey: "pricing.8.title",
    rangeKey: "pricing.8.range",
    descKey: "pricing.8.desc",
    waMsgKey: "security"
  }
];
---

<section id="pricing" class="bg-background">
  <div class="section-container">
    <div class="reveal">
      <SectionHeading
        badge={t("pricing.badge")}
        title={t("pricing.title")}
        subtitle={t("pricing.subtitle")}
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {
        pricingData.map((item, i) => {
          const waMsg = waMessages[item.waMsgKey as keyof typeof waMessages] || waMessages.general;
          const waHref = whatsappLink(waMsg);
          
          const tgHref = telegramLink(item.value);
          const tgTextKey = `telegram.cta.${item.value}` as const;
          const tgTextVal = t(tgTextKey as any);
          const tgText = tgTextVal !== tgTextKey ? tgTextVal : t('telegram.cta.default');
          
          return (
            <div class="reveal" style={`transition-delay: ${(i % 3) * 0.1}s`}>
              <div class="card card-hover p-6 md:p-8 group flex flex-col h-full border border-white/5 bg-gradient-to-b from-surface/40 to-surface-dim hover:border-primary/30">
                <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-2xl mb-5 group-hover:scale-110 group-hover:bg-primary/20 transition-all duration-300">
                  {item.icon}
                </div>
                <h3 class="font-display font-semibold text-lg text-text-heading mb-2">
                  {t(item.titleKey as any)}
                </h3>
                <div class="text-primary font-bold text-xl mb-3">
                  {t(item.rangeKey as any)}
                </div>
                <p class="text-text-body text-sm leading-relaxed flex-1 mb-6">
                  {t(item.descKey as any)}
                </p>
                
                <div class="mt-auto space-y-4 pt-4 border-t border-border/50">
                  <div class="flex items-center justify-between gap-4">
                    <a href="/cotizar" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-dark transition-colors">
                      {t('pricing.cta')}
                      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </a>
                    <a href={waHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm font-semibold text-[#25D366] hover:text-[#1fb855] transition-colors" title="Contactar por WhatsApp">
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    </a>
                  </div>
                  
                  <div class="flex flex-col gap-2 pt-2">
                    <a href={tgHref} target="_blank" rel="noopener noreferrer" class="btn-secondary w-full text-sm py-2 px-4 flex items-center justify-center gap-2">
                      <svg class="w-4 h-4 text-[#229ED9]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.446 1.394c-.14.18-.357.295-.6.295-.002 0-.003 0-.005 0l.213-3.054 5.56-5.022c.24-.213-.054-.334-.373-.121l-6.869 4.326-2.96-.924c-.64-.203-.658-.64.135-.954l11.566-4.458c.538-.196 1.006.128.832.94z"/></svg>
                      {tgText}
                    </a>
                    <p class="text-xs text-text-muted text-center px-1">
                      {t('telegram.microcopy')}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>

    <div class="reveal max-w-4xl mx-auto space-y-4">
      <div class="p-6 rounded-2xl bg-primary/5 border border-primary/20 flex flex-col md:flex-row gap-4 items-start md:items-center">
        <div class="text-primary text-2xl flex-shrink-0">⚠️</div>
        <p class="text-text-body text-sm leading-relaxed">
          <strong>{t('pricing.disclaimer')}</strong>
        </p>
      </div>
      
      <div class="p-6 rounded-2xl bg-surface-dim border border-border flex flex-col md:flex-row gap-4 items-start md:items-center">
        <div class="text-secondary text-2xl flex-shrink-0">🤝</div>
        <p class="text-text-body text-sm leading-relaxed">
          {t('pricing.honesty')}
        </p>
      </div>
    </div>
  </div>
</section>
