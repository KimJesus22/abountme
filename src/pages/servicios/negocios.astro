---
import MainLayout from '../../layouts/MainLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import FeatureGrid from '../../components/ui/FeatureGrid.astro';
import BusinessSolutions from '../../components/sections/BusinessSolutions.astro';
import PageCTA from '../../components/ui/PageCTA.astro';
import { businessFeatures } from '../../data/servicePages';

const lang = 'es';
---

<MainLayout
  lang={lang}
  title="Digitalizacion para negocios | JC21 Labs"
  description="WhatsApp Business, QR, Google Maps, catálogos y menús digitales para negocios pequeños."
>
  <PageHero
    badge="Negocios"
    title="Digitalización para negocios pequeños"
    subtitle="Te ayudo a que tu negocio tenga presencia más clara: WhatsApp Business, QR, Google Maps, catálogo, menú digital y página sencilla."
  />
  <FeatureGrid title="Soluciones para negocios" features={businessFeatures} />
  <BusinessSolutions />
  <PageCTA title="Quieres digitalizar tu negocio?" />
</MainLayout>
