---
import MainLayout from '../../layouts/MainLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import FeatureGrid from '../../components/ui/FeatureGrid.astro';
import Projects from '../../components/sections/Projects.astro';
import PageCTA from '../../components/ui/PageCTA.astro';
import { webFeatures } from '../../data/servicePages';

const lang = 'es';
---

<MainLayout
  lang={lang}
  title="Páginas web | JC21 Labs"
  description="Páginas web sencillas, menús digitales, portafolios y proyectos personalizados."
>
  <PageHero
    badge="Páginas web"
    title="Páginas web sencillas y proyectos personalizados"
    subtitle="Sitios claros para negocios, servicios, portafolios, menús digitales o ideas pequeñas que necesitan verse profesionales en internet."
  />
  <FeatureGrid title="Tipos de proyectos web" features={webFeatures} />
  <Projects lang={lang} />
  <PageCTA title="Quieres una página web sencilla?" />
</MainLayout>
