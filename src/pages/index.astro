---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Services from '../components/sections/Services.astro';
import ServiceLinks from '../components/ui/ServiceLinks.astro';
import Projects from '../components/sections/Projects.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import QuoteForm from '../components/sections/QuoteForm.astro';
import Contact from '../components/sections/Contact.astro';

const lang = 'en';
---

<MainLayout 
  lang={lang}
  title="JC21 Labs — Clear Technology for Real People and Businesses"
  description="Technology solutions for people and small businesses. Tech support, websites, digital security, and more. From Jaral del Progreso to all of Mexico."
>
  <Hero lang={lang} />
  <ServiceLinks />
  <Services lang={lang} />
  <Projects lang={lang} />
  <Testimonials />
  <QuoteForm lang={lang} />
  <Contact lang={lang} />
</MainLayout>
