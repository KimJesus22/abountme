---
import MainLayout from '../../layouts/MainLayout.astro';
import { serviceChecklists } from '../../data/checklists';
---
<MainLayout title="Admin - Cotizaciones" lang="es">
  <section class="min-h-screen bg-background pt-32 pb-12 px-4 sm:px-6 lg:px-8">
    <div id="auth-container" class="max-w-md mx-auto bg-surface p-8 rounded-2xl border border-border shadow-sm hidden">
      <h2 class="text-2xl font-bold mb-6 text-text-heading text-center">Acceso Administrador</h2>
      <form id="login-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Correo Electrónico</label>
          <input type="email" id="email" required class="w-full px-4 py-2 rounded-lg border border-border bg-background text-text-heading" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Contraseña</label>
          <input type="password" id="password" required class="w-full px-4 py-2 rounded-lg border border-border bg-background text-text-heading" />
        </div>
        <button type="submit" class="w-full py-2 bg-primary text-background rounded-lg font-medium hover:opacity-90 transition-opacity">Iniciar Sesión</button>
        <p id="login-error" class="text-error text-sm hidden"></p>
      </form>
    </div>

    <div id="dashboard-container" class="max-w-7xl mx-auto hidden">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
        <h1 class="text-3xl font-bold text-text-heading">Cotizaciones Recibidas</h1>
        <button id="logout-btn" class="px-4 py-2 border border-border text-text rounded-lg hover:bg-border/50 transition-colors">Cerrar Sesión</button>
      </div>

      <div class="bg-surface rounded-2xl border border-border overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="bg-background border-b border-border text-text-heading">
              <tr>
                <th class="p-4 font-semibold whitespace-nowrap">Fecha</th>
                <th class="p-4 font-semibold whitespace-nowrap">Cliente</th>
                <th class="p-4 font-semibold whitespace-nowrap">Servicio</th>
                <th class="p-4 font-semibold whitespace-nowrap">Urgencia</th>
                <th class="p-4 font-semibold whitespace-nowrap">Estado</th>
                <th class="p-4 font-semibold text-right whitespace-nowrap">Acciones</th>
              </tr>
            </thead>
            <tbody id="quotes-list" class="divide-y divide-border">
              <!-- Carga dinámica -->
            </tbody>
          </table>
        </div>
      </div>
      
      <div class="mt-16 mb-8">
        <h2 class="text-2xl font-bold text-text-heading mb-6">Checklists para Cotizar</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {serviceChecklists.map(list => (
            <div class="bg-surface border border-border rounded-2xl p-6 shadow-sm flex flex-col">
              <h3 class="font-bold text-lg text-primary mb-4 border-b border-border/50 pb-2">{list.title}</h3>
              <ul class="space-y-3">
                {list.items.map(item => (
                  <li class="flex items-start gap-2 text-sm text-text-body">
                    <svg class="w-4 h-4 text-success mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span class="leading-tight">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Modal -->
  <div id="quote-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden bg-black/50 backdrop-blur-sm p-4">
    <div class="bg-surface w-full max-w-2xl max-h-[90vh] overflow-y-auto rounded-2xl border border-border shadow-2xl p-5 sm:p-6 md:p-8 relative">
      <button id="close-modal" class="absolute top-4 right-4 text-text hover:text-text-heading p-2 rounded-full hover:bg-border/50 transition-colors">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
      
      <h2 class="text-2xl font-bold mb-6 text-text-heading pr-8">Detalle de Cotización</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="bg-background p-3 rounded-xl border border-border">
          <strong class="block text-[10px] text-text/70 uppercase tracking-wider mb-1">Nombre</strong> 
          <span id="modal-name" class="font-medium text-text-heading text-sm"></span>
        </div>
        <div class="bg-background p-3 rounded-xl border border-border">
          <strong class="block text-[10px] text-text/70 uppercase tracking-wider mb-1">Teléfono</strong> 
          <span id="modal-phone" class="font-medium text-text-heading text-sm"></span>
        </div>
        <div class="bg-background p-3 rounded-xl border border-border">
          <strong class="block text-[10px] text-text/70 uppercase tracking-wider mb-1">Email</strong> 
          <span id="modal-email" class="font-medium text-text-heading text-sm"></span>
        </div>
        <div class="bg-background p-3 rounded-xl border border-border">
          <strong class="block text-[10px] text-text/70 uppercase tracking-wider mb-1">Ciudad</strong> 
          <span id="modal-city" class="font-medium text-text-heading text-sm"></span>
        </div>
        <div class="bg-background p-3 rounded-xl border border-border">
          <strong class="block text-[10px] text-text/70 uppercase tracking-wider mb-1">Tipo de Atención</strong> 
          <span id="modal-attention" class="font-medium text-text-heading text-sm capitalize"></span>
        </div>
        <div class="bg-background p-3 rounded-xl border border-border">
          <strong class="block text-[10px] text-text/70 uppercase tracking-wider mb-1">Servicio</strong> 
          <span id="modal-service" class="font-medium text-primary text-sm"></span>
        </div>
        <div class="bg-background p-3 rounded-xl border border-border">
          <strong class="block text-[10px] text-text/70 uppercase tracking-wider mb-1">Urgencia</strong> 
          <span id="modal-urgency" class="font-medium text-text-heading text-sm capitalize"></span>
        </div>
        <div class="bg-background p-3 rounded-xl border border-border">
          <strong class="block text-[10px] text-text/70 uppercase tracking-wider mb-1">Presupuesto</strong> 
          <span id="modal-budget" class="font-medium text-success text-sm"></span>
        </div>
      </div>
      
      <div class="mb-6">
        <strong class="block text-xs text-text/70 uppercase tracking-wider mb-2">Descripción de la necesidad</strong>
        <p id="modal-description" class="bg-background p-4 rounded-xl border border-border text-sm whitespace-pre-wrap text-text-heading leading-relaxed"></p>
      </div>

      <div id="telegram-reply-box" class="hidden mb-6 bg-background p-4 rounded-xl border border-border">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
          <strong class="block text-xs text-text/70 uppercase tracking-wider">Responder por Telegram</strong>
          <span id="telegram-chat-id-label" class="text-xs text-text/50"></span>
        </div>

        <div id="telegram-history" class="max-h-64 overflow-y-auto space-y-3 mb-4 pr-1 text-sm"></div>

        <div class="space-y-3">
          <textarea id="telegram-reply-message" rows="3" class="w-full px-4 py-3 rounded-xl border border-border bg-surface text-text-heading resize-none focus:ring-2 focus:ring-primary/30 outline-none placeholder-text/30" placeholder="Escribe tu respuesta para el usuario..."></textarea>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <p id="telegram-reply-feedback" class="text-sm font-medium hidden"></p>
            <button id="telegram-send-reply" type="button" class="px-5 py-2.5 bg-primary text-background rounded-xl font-medium hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed">Enviar por Telegram</button>
          </div>
        </div>
      </div>

      <hr class="border-border my-6" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wider mb-2 text-text-heading">Cambiar Estado</label>
          <select id="modal-status" class="w-full px-4 py-3 rounded-xl border border-border bg-background text-text-heading focus:ring-2 focus:ring-primary/30 outline-none">
            <option value="nueva">Nueva</option>
            <option value="contactado">Contactado</option>
            <option value="en revisión">En revisión</option>
            <option value="cotizado">Cotizado</option>
            <option value="aceptado">Aceptado</option>
            <option value="rechazado">Rechazado</option>
            <option value="cerrado">Cerrado</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wider mb-2 text-text-heading">Notas Internas</label>
          <textarea id="modal-notes" rows="4" class="w-full px-4 py-3 rounded-xl border border-border bg-background text-text-heading resize-none focus:ring-2 focus:ring-primary/30 outline-none placeholder-text/30" placeholder="Anota aquí acuerdos, costos estimados, materiales necesarios..."></textarea>
        </div>
      </div>

      <div class="flex justify-end items-center gap-4">
        <p id="modal-feedback" class="text-sm font-medium hidden"></p>
        <button id="save-modal" class="px-6 py-2.5 bg-primary text-background rounded-xl font-medium hover:opacity-90 transition-opacity">Guardar Cambios</button>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { insforge } from '../../lib/insforge';
  import { formatAttentionType, formatServiceType } from '../../lib/quotes/formatters';

  const authContainer = document.getElementById('auth-container');
  const dashboardContainer = document.getElementById('dashboard-container');
  const loginForm = document.getElementById('login-form');
  const logoutBtn = document.getElementById('logout-btn');
  const quotesList = document.getElementById('quotes-list');
  const loginError = document.getElementById('login-error');
  
  // Modal elements
  const modal = document.getElementById('quote-modal');
  const closeModal = document.getElementById('close-modal');
  const saveModal = document.getElementById('save-modal');
  const modalFeedback = document.getElementById('modal-feedback');
  const telegramReplyBox = document.getElementById('telegram-reply-box');
  const telegramChatIdLabel = document.getElementById('telegram-chat-id-label');
  const telegramHistory = document.getElementById('telegram-history');
  const telegramReplyMessage = document.getElementById('telegram-reply-message');
  const telegramReplyFeedback = document.getElementById('telegram-reply-feedback');
  const telegramSendReply = document.getElementById('telegram-send-reply');
  let currentQuoteId = null;
  let currentTelegramChatId = null;
  let quotesData = [];

  // Init
  async function init() {
    const { data, error } = await insforge.auth.getCurrentUser();
    if (data?.user) {
      showDashboard();
    } else {
      authContainer.classList.remove('hidden');
    }
  }

  // Auth Events
  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const btn = loginForm.querySelector('button');
    
    loginError.classList.add('hidden');
    btn.textContent = "Iniciando...";
    btn.disabled = true;

    const { error } = await insforge.auth.signInWithPassword({ email, password });
    
    if (error) {
      loginError.textContent = "Credenciales incorrectas.";
      loginError.classList.remove('hidden');
      btn.textContent = "Iniciar Sesión";
      btn.disabled = false;
    } else {
      showDashboard();
    }
  });

  logoutBtn.addEventListener('click', async () => {
    await insforge.auth.signOut();
    dashboardContainer.classList.add('hidden');
    authContainer.classList.remove('hidden');
    loginForm.reset();
  });

  // Dashboard logic
  async function showDashboard() {
    authContainer.classList.add('hidden');
    dashboardContainer.classList.remove('hidden');
    loadQuotes();
  }

  async function loadQuotes() {
    quotesList.innerHTML = '<tr><td colspan="6" class="p-8 text-center text-text/50">Cargando cotizaciones...</td></tr>';

    const authHeaders = insforge.getHttpClient?.().getHeaders?.() || {};
    const authorization = authHeaders.Authorization || authHeaders.authorization;

    if (!authorization) {
      quotesList.innerHTML = '<tr><td colspan="6" class="p-8 text-center text-error">No se encontró una sesión activa de administrador.</td></tr>';
      return;
    }

    try {
      const response = await fetch('/api/admin/quotes', {
        method: 'GET',
        headers: {
          Authorization: authorization,
        },
        cache: 'no-store',
      });

      const result = await response.json().catch(() => ({}));
      if (!response.ok) {
        throw new Error(result.error || 'No se pudieron cargar las cotizaciones.');
      }

      quotesData = result.quotes || [];
    } catch (error) {
      console.error(error);
      quotesList.innerHTML = '<tr><td colspan="6" class="p-8 text-center text-error">No se pudieron cargar las cotizaciones.</td></tr>';
      return;
    }

    renderQuotes();
  }

  function getStatusBadge(status) {
    // Definimos colores que combinen con cualquier theme
    const statusMap = {
      'nueva': 'bg-blue-500/10 text-blue-500 border-blue-500/20',
      'contactado': 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20',
      'en revisión': 'bg-purple-500/10 text-purple-500 border-purple-500/20',
      'cotizado': 'bg-indigo-500/10 text-indigo-500 border-indigo-500/20',
      'aceptado': 'bg-green-500/10 text-green-500 border-green-500/20',
      'rechazado': 'bg-red-500/10 text-red-500 border-red-500/20',
      'cerrado': 'bg-gray-500/10 text-gray-500 border-gray-500/20',
    };
    const c = statusMap[status] || statusMap['nueva'];
    return `<span class="px-3 py-1 text-xs font-semibold rounded-full border ${c} uppercase tracking-wider">${status || 'nueva'}</span>`;
  }

  function renderQuotes() {
    if (quotesData.length === 0) {
      quotesList.innerHTML = '<tr><td colspan="6" class="p-8 text-center text-text/50">No hay cotizaciones recibidas aún.</td></tr>';
      return;
    }

    quotesList.innerHTML = quotesData.map(q => {
      const date = new Date(q.created_at).toLocaleDateString('es-MX', {
        month: 'short', day: 'numeric', hour: '2-digit', minute:'2-digit'
      });
      return `
        <tr class="hover:bg-surface/50 transition-colors group">
          <td class="p-4 whitespace-nowrap text-text/70">${date}</td>
          <td class="p-4 font-medium text-text-heading min-w-[200px]">${q.full_name} <br/><span class="text-xs text-text/50 font-normal">${q.city} • ${q.phone}</span></td>
          <td class="p-4 text-text-body whitespace-nowrap">${formatServiceType(q.service_type)}</td>
          <td class="p-4 capitalize text-text-body whitespace-nowrap">${q.urgency}</td>
          <td class="p-4 whitespace-nowrap">${getStatusBadge(q.status)}</td>
          <td class="p-4 text-right whitespace-nowrap">
            <button class="view-btn px-4 py-2 bg-primary/10 text-primary text-sm font-medium rounded-lg hover:bg-primary/20 transition-colors opacity-80 group-hover:opacity-100" data-id="${q.id}">Revisar</button>
          </td>
        </tr>
      `;
    }).join('');

    document.querySelectorAll('.view-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = e.currentTarget.getAttribute('data-id');
        openModal(id);
      });
    });
  }

  function showTelegramFeedback(message, type = 'success') {
    telegramReplyFeedback.textContent = message;
    telegramReplyFeedback.className = `text-sm font-medium ${type === 'error' ? 'text-error' : 'text-success'}`;
    telegramReplyFeedback.classList.remove('hidden');
  }

  function renderTelegramHistory(messages) {
    if (!currentTelegramChatId) {
      telegramHistory.innerHTML = '';
      return;
    }

    if (!messages || messages.length === 0) {
      telegramHistory.innerHTML = '<p class="text-text/50">Aún no hay mensajes guardados para esta cotización.</p>';
      return;
    }

    telegramHistory.innerHTML = '';
    messages.forEach((msg) => {
      const row = document.createElement('div');
      const isOutbound = msg.direction === 'outbound';
      row.className = `flex ${isOutbound ? 'justify-end' : 'justify-start'}`;

      const bubble = document.createElement('div');
      bubble.className = `max-w-[85%] rounded-xl border px-3 py-2 ${isOutbound ? 'bg-primary/10 border-primary/20 text-text-heading' : 'bg-surface border-border text-text-body'}`;

      const meta = document.createElement('div');
      meta.className = 'mb-1 text-[10px] uppercase tracking-wider text-text/50';
      const createdAt = msg.created_at ? new Date(msg.created_at).toLocaleString('es-MX') : '';
      meta.textContent = `${isOutbound ? 'José' : 'Usuario'}${createdAt ? ` • ${createdAt}` : ''}`;

      const text = document.createElement('p');
      text.className = 'whitespace-pre-wrap leading-relaxed';
      text.textContent = msg.message_text || '';

      bubble.append(meta, text);
      row.appendChild(bubble);
      telegramHistory.appendChild(row);
    });
  }

  async function loadTelegramHistory(quoteId) {
    telegramHistory.innerHTML = '<p class="text-text/50">Cargando historial...</p>';

    const { data, error } = await insforge.database
      .from('telegram_messages')
      .select('*')
      .eq('quote_id', quoteId)
      .order('created_at', { ascending: true });

    if (error) {
      telegramHistory.innerHTML = '<p class="text-error">No se pudo cargar el historial de Telegram.</p>';
      return;
    }

    renderTelegramHistory(data || []);
  }

  // Modal logic
  function openModal(id) {
    const q = quotesData.find(x => x.id === id);
    if (!q) return;
    
    currentQuoteId = id;
    currentTelegramChatId = q.telegram_chat_id || null;
    document.getElementById('modal-name').textContent = q.full_name || '-';
    document.getElementById('modal-phone').textContent = q.phone || '-';
    document.getElementById('modal-email').textContent = q.email || '-';
    document.getElementById('modal-city').textContent = q.city || '-';
    document.getElementById('modal-attention').textContent = formatAttentionType(q.attention_type);
    document.getElementById('modal-service').textContent = formatServiceType(q.service_type);
    document.getElementById('modal-urgency').textContent = q.urgency || '-';
    document.getElementById('modal-budget').textContent = q.budget || '-';
    document.getElementById('modal-description').textContent = q.description || '-';
    
    document.getElementById('modal-status').value = q.status || 'nueva';
    document.getElementById('modal-notes').value = q.notes || '';

    telegramReplyMessage.value = '';
    telegramReplyFeedback.classList.add('hidden');
    if (currentTelegramChatId) {
      telegramChatIdLabel.textContent = `Chat ID: ${currentTelegramChatId}`;
      telegramReplyBox.classList.remove('hidden');
      loadTelegramHistory(currentQuoteId);
    } else {
      telegramReplyBox.classList.add('hidden');
      telegramHistory.innerHTML = '';
    }
    
    modalFeedback.classList.add('hidden');
    modal.classList.remove('hidden');
  }

  closeModal.addEventListener('click', () => {
    modal.classList.add('hidden');
  });

  // Close modal when clicking outside
  modal.addEventListener('click', (e) => {
    if(e.target === modal) {
      modal.classList.add('hidden');
    }
  });

  telegramSendReply.addEventListener('click', async () => {
    if (!currentQuoteId || !currentTelegramChatId) return;

    const message = telegramReplyMessage.value.trim();
    if (!message) {
      showTelegramFeedback('Escribe un mensaje antes de enviarlo.', 'error');
      return;
    }

    const authHeaders = insforge.getHttpClient?.().getHeaders?.() || {};
    const authorization = authHeaders.Authorization || authHeaders.authorization;
    if (!authorization) {
      showTelegramFeedback('No se encontró una sesión activa de administrador.', 'error');
      return;
    }

    telegramSendReply.disabled = true;
    telegramSendReply.textContent = 'Enviando...';
    telegramReplyFeedback.classList.add('hidden');

    try {
      const response = await fetch('/api/admin/telegram-reply', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: authorization,
        },
        body: JSON.stringify({
          quoteId: currentQuoteId,
          telegramChatId: currentTelegramChatId,
          message,
        }),
      });

      const result = await response.json().catch(() => ({}));
      if (!response.ok) {
        throw new Error(result.error || 'No se pudo enviar el mensaje.');
      }

      telegramReplyMessage.value = '';
      showTelegramFeedback('Mensaje enviado por Telegram.');
      await loadTelegramHistory(currentQuoteId);
    } catch (error) {
      console.error(error);
      showTelegramFeedback(error.message || 'No se pudo enviar el mensaje.', 'error');
    } finally {
      telegramSendReply.disabled = false;
      telegramSendReply.textContent = 'Enviar por Telegram';
    }
  });

  saveModal.addEventListener('click', async () => {
    if (!currentQuoteId) return;
    
    const newStatus = document.getElementById('modal-status').value;
    const newNotes = document.getElementById('modal-notes').value;
    
    saveModal.disabled = true;
    saveModal.textContent = 'Guardando...';
    
    const { error } = await insforge.database
      .from('quotes')
      .update({ status: newStatus, notes: newNotes })
      .eq('id', currentQuoteId);
      
    if (error) {
      modalFeedback.textContent = 'Error al guardar cambios.';
      modalFeedback.className = 'text-sm text-error';
    } else {
      modalFeedback.textContent = '✔ Guardado correctamente';
      modalFeedback.className = 'text-sm text-success';
      // Update local state
      const idx = quotesData.findIndex(x => x.id === currentQuoteId);
      if (idx > -1) {
        quotesData[idx].status = newStatus;
        quotesData[idx].notes = newNotes;
      }
      renderQuotes();
      setTimeout(() => { 
        if(!modal.classList.contains('hidden')) {
          modal.classList.add('hidden'); 
        }
      }, 1000);
    }
    
    modalFeedback.classList.remove('hidden');
    saveModal.disabled = false;
    saveModal.textContent = 'Guardar Cambios';
  });

  // Init on load
  init();
</script>
