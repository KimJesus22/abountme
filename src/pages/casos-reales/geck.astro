---
import MainLayout from '../../layouts/MainLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';

const lang = 'es';
const githubUrl = 'https://github.com/KimJesus22/GECK';

const workItems = [
  'Estructura de la página',
  'Diseño visual básico',
  'Funcionalidad para carga de archivos',
  'Acompañamiento durante el desarrollo',
  'Ajustes según necesidades de la clienta',
];

const technologies = [
  'HTML',
  'CSS',
  'JavaScript',
  'Lista editable según el repositorio',
];
---

<MainLayout
  lang={lang}
  title="GECK — Plataforma sencilla para capacitación de personal | JC21 Labs"
  description="Proyecto web realizado para una clienta real: página sencilla para capacitación de personal con carga y consulta de archivos."
>
  <PageHero
    badge="Caso de estudio"
    title="GECK — Plataforma sencilla para capacitación de personal"
    subtitle="Proyecto web realizado para una clienta real"
  />

  <section class="bg-background">
    <div class="section-container pt-0">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
        <aside class="lg:col-span-4 space-y-5">
          <div class="card p-6">
            <p class="text-xs uppercase tracking-wider text-text/60 mb-2">Tipo de proyecto</p>
            <p class="font-semibold text-text-heading">Página web sencilla</p>
          </div>
          <div class="card p-6">
            <p class="text-xs uppercase tracking-wider text-text/60 mb-2">Cliente</p>
            <p class="font-semibold text-text-heading">Clienta real</p>
          </div>
          <div class="card p-6">
            <p class="text-xs uppercase tracking-wider text-text/60 mb-2">Costo</p>
            <p class="font-semibold text-text-heading">$1,600 MXN</p>
          </div>
          <div class="card p-6">
            <p class="text-xs uppercase tracking-wider text-text/60 mb-3">Repositorio público</p>
            <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary w-full">
              Ver repositorio en GitHub
            </a>
          </div>
        </aside>

        <div class="lg:col-span-8 space-y-6">
          <article class="card p-6 md:p-8">
            <h2 class="text-2xl font-bold text-text-heading mb-4">Resumen del proyecto</h2>
            <p class="text-text-body leading-relaxed">
              GECK es una página web sencilla creada para apoyar la capacitación de personal mediante la carga y consulta de archivos. El objetivo fue facilitar que una empresa pudiera organizar material útil para su equipo dentro de un proyecto universitario.
            </p>
          </article>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <article class="card p-6 md:p-8">
              <h2 class="text-2xl font-bold text-text-heading mb-4">Problema</h2>
              <p class="text-text-body leading-relaxed">
                La clienta necesitaba una solución clara y funcional para presentar o compartir archivos relacionados con capacitación de personal.
              </p>
            </article>

            <article class="card p-6 md:p-8">
              <h2 class="text-2xl font-bold text-text-heading mb-4">Solución</h2>
              <p class="text-text-body leading-relaxed">
                Se desarrolló una página web sencilla con enfoque práctico, permitiendo subir archivos y organizar el contenido de forma entendible.
              </p>
            </article>
          </div>

          <article class="card p-6 md:p-8">
            <h2 class="text-2xl font-bold text-text-heading mb-5">Mi trabajo</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {workItems.map((item) => (
                <li class="flex items-start gap-3 rounded-xl border border-border bg-background p-4">
                  <span class="text-primary mt-0.5">✓</span>
                  <span class="text-sm font-medium text-text-heading">{item}</span>
                </li>
              ))}
            </ul>
          </article>

          <article class="card p-6 md:p-8">
            <h2 class="text-2xl font-bold text-text-heading mb-4">Resultado</h2>
            <p class="text-text-body leading-relaxed">
              Fue mi primer proyecto pagado para una clienta real, con un costo de $1,600 MXN.
            </p>
          </article>

          <article class="card p-6 md:p-8">
            <h2 class="text-2xl font-bold text-text-heading mb-5">Tecnologías</h2>
            <div class="flex flex-wrap gap-2">
              {technologies.map((tech) => (
                <span class="rounded-full bg-primary/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary">
                  {tech}
                </span>
              ))}
            </div>
          </article>

          <article class="card p-6 md:p-8 border-primary/20 bg-primary/5">
            <h2 class="text-2xl font-bold text-text-heading mb-4">Reseña</h2>
            <p class="italic text-text-body leading-relaxed">
              “Reseña pendiente de autorización/publicación.”
            </p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-primary/5 border-y border-primary/10">
    <div class="section-container py-14 md:py-16">
      <div class="flex flex-col lg:flex-row gap-6 lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <h2 class="text-2xl md:text-3xl font-bold text-text-heading">¿Quieres una página sencilla para tu proyecto?</h2>
          <p class="mt-3 text-text-body leading-relaxed">
            Puedo ayudarte a aterrizar una idea pequeña, explicar qué conviene hacer primero y cotizar una solución clara.
          </p>
        </div>
        <a href="/cotizar" class="btn-primary">Cotizar una página similar</a>
      </div>
    </div>
  </section>
</MainLayout>
